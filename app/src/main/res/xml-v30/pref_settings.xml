<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory android:title="@string/disasmTheme">
        <ListPreference
            android:defaultValue="0"
            android:entries="@array/predefinedcolor"
            android:entryValues="@array/predefinedcolor_values"
            android:icon="@drawable/ic_pref_palette"
            android:key="predefinedcolor"
            android:negativeButtonText="@null"
            android:positiveButtonText="@null"
            android:title="@string/pref_theme_choose" />
        <!--com.skydoves.colorpickerpreference.ColorPickerPreference
        android:key="h"
        android:title="Toolbar Color"
        android:summary="changes toolbar color"
        app:preference_dialog_title="Toolbar ColorPickerDialog"
        app:preference_dialog_positive="confirm"
        app:preference_dialog_negative="cancel"
        app:preference_palette="palette"
        app:preference_selector="wheel"
        app:default_color="colorPrimary"/-->
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/power_user_features">
        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="power_user_import_mode"
            android:summary="@string/power_user_import_summary"
            android:title="@string/power_user_import_title" />
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="power_user_filesystem_import"
            android:summary="@string/power_user_filesystem_import_summary"
            android:title="@string/power_user_filesystem_import_title" />
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="power_user_apps_import"
            android:summary="@string/power_user_apps_import_summary"
            android:title="@string/power_user_apps_import_title" />
        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="power_user_research_tools_import"
            android:summary="@string/power_user_research_tools_import_summary"
            android:title="@string/power_user_research_tools_import_title" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/app_info">
        <Preference
            android:fragment="com.kyhsgeekcode.disassembler.preference.DeveloperInfoFragment"
            android:icon="@drawable/ic_pref_person"
            android:summary="@string/dev_info"
            android:title="@string/dev_info_detail" />
        <Preference
            android:icon="@drawable/ic_pref_bug"
            android:summary="@string/send_mail_detail"
            android:title="@string/send_mail">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/NX-developer/NX-so-decompiler/issues/new" />
        </Preference>
        <Preference
            android:icon="@drawable/ic_pref_lightbulb"
            android:summary="@string/send_feature_request_detail"
            android:title="@string/send_feature_request">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/NX-developer/NX-so-decompiler/issues/new" />
        </Preference>
        <Preference
            android:icon="@drawable/ic_pref_book"
            android:key="readme"
            android:summary="@string/pref_manual_summary"
            android:title="@string/pref_manual_title">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/NX-developer/NX-so-decompiler#readme" />
        </Preference>

        <Preference
            android:icon="@drawable/ic_pref_license"
            android:key="openscrn"
            android:summary="@string/pref_license_summary"
            android:title="@string/pref_license_title"></Preference>
    </PreferenceCategory>
</PreferenceScreen>
